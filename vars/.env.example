# Шаблон переменных окружения (можно скопировать в `vars/.env.development` при необходимости).
# Репозиторий содержит версионируемый `vars/.env.development` с рабочими значениями Docker;
# отредактируйте в нём только секреты (Telegram, Kinopoisk).

# URL приложения для Vite proxy (хост:порт бэкенда снаружи Docker)
VITE_API_ORIGIN=http://127.0.0.1:6749

# Режим приложения: dev | prod | test (pytest выставляет test в conftest)
ENV=dev
RELOAD=true
HOST=0.0.0.0
PORT=8000

# В контейнере backend: postgresql://...@filmony-postgres:5432/filmony
# С хоста при ручных утилитах: postgresql://...@127.0.0.1:55432/filmony
DATABASE_URL=postgresql://filmony:filmony@filmony-postgres:5432/filmony
DATABASE_SCHEMA=public
DATABASE_TEST_SCHEMA=filmony_test
# DATABASE_ECHO=false

# Публичный base URL для картинок реакций (без trailing slash): {base}/{asset_key}
REACTION_MEDIA_PUBLIC_BASE_URL=http://127.0.0.1:7900/filmony-reactions

# RustFS / S3 — хост (синк-скрипт, mc), bucket как в compose/sync
RUSTFS_ENDPOINT=http://127.0.0.1:7900
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET=filmony-reactions

# Telegram
TG_APP_TOKEN=
TELEGRAM_BOT_USERNAME=dev_filmony_bot

# JWT для httpOnly-сессии (в dev можно длинная произвольная строка)
AUTH_JWT_SECRET=
SESSION_COOKIE_NAME=filmony_session
SESSION_MAX_AGE_SECONDS=604800

# Kinopoisk API Unofficial
KINOPOISK_API_KEY=
KINOPOISK_API_BASE_URL=https://kinopoiskapiunofficial.tech/api
KINOPOISK_API_TIMEOUT_SECONDS=8

# Профиль: размер страницы списка карточек (опционально)
# PROFILE_CARDS_PAGE_SIZE_DEFAULT=20
# PROFILE_CARDS_PAGE_SIZE_MAX=50
