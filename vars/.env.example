# URL приложения для Vite proxy (хост:порт бэкенда)
VITE_API_ORIGIN=http://127.0.0.1:6749

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_SCHEMA=public
DATABASE_TEST_SCHEMA=filmony_test
# DATABASE_ECHO=false

# Режим приложения: dev | prod | test (pytest выставляет test в conftest)
# ENV=dev

# Telegram
TG_APP_TOKEN=
TELEGRAM_BOT_USERNAME=

# JWT для httpOnly-сессии
AUTH_JWT_SECRET=
