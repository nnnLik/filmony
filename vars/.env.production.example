ENV=prod
RELOAD=false
HOST=0.0.0.0
PORT=8000

POSTGRES_USER=filmony
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=filmony

DATABASE_URL=postgresql://filmony:CHANGE_ME@filmony-postgres:5432/filmony
DATABASE_SCHEMA=public
DATABASE_TEST_SCHEMA=filmony_test

CORS_ALLOW_ORIGINS=["https://app.example.com"]

REACTION_MEDIA_PUBLIC_BASE_URL=https://api.example.com

RUSTFS_CONSOLE_ENABLE=false
RUSTFS_INTERNAL_BASE_URL=http://filmony-rustfs:9000
RUSTFS_ACCESS_KEY=
RUSTFS_SECRET_KEY=
RUSTFS_BUCKET=filmony-reactions

TG_APP_TOKEN=
TELEGRAM_BOT_USERNAME=
AUTH_JWT_SECRET=
SESSION_COOKIE_NAME=filmony_session
SESSION_MAX_AGE_SECONDS=604800

KINOPOISK_API_KEY=
KINOPOISK_API_BASE_URL=https://kinopoiskapiunofficial.tech/api
KINOPOISK_API_TIMEOUT_SECONDS=8

CELERY_BROKER_URL=redis://filmony-redis:6379/0
CELERY_RESULT_BACKEND=redis://filmony-redis:6379/1
